<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/app_card"
    app:strokeColor="#1A10B981"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/text_magic_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔮 Globul de Cristal"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/text_magic_instruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Alege o categorie și apasă pe glob"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Category Selection Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_magic_cats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="8dp"
            android:gravity="center">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_magic_food"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍕 Mâncare" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_magic_fun"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎮 Distracție" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_magic_relax"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧘 Relaxare" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_magic_culture"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏛️ Cultural" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Crystal Ball Container with Green Glow -->
        <RelativeLayout
            android:id="@+id/layout_magic_ball_container"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginVertical="12dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Outer Glow Layer 1 -->
            <View
                android:id="@+id/view_glow_1"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_magic_glow"
                android:alpha="0.3"
                app:tint="#10B981" />

            <!-- Outer Glow Layer 2 -->
            <View
                android:id="@+id/view_glow_2"
                android:layout_width="210dp"
                android:layout_height="210dp"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_magic_glow"
                android:alpha="0.2"
                app:tint="#A7F3D0" />

            <!-- Main Crystal Ball Sphere -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_centerInParent="true"
                app:cardCornerRadius="90dp"
                app:cardBackgroundColor="#065F46"
                app:strokeColor="#10B981"
                app:strokeWidth="2.5dp"
                app:cardElevation="8dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Gradient Cosmic Background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_magic_gradient" />

                    <!-- Animated Particle Overlay -->
                    <ImageView
                        android:id="@+id/img_magic_particles"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_magic_particles"
                        android:alpha="0.4" />

                    <!-- Mist Transition Effect -->
                    <ImageView
                        android:id="@+id/img_magic_reveal_mist"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0.7"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_magic_mist" />

                    <!-- Actual generated green crystal ball image -->
                    <ImageView
                        android:id="@+id/img_magic_reveal_ball"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/img_green_crystal_ball" />

                    <!-- Prediction Text with Glow (Hidden until revealed) -->
                    <TextView
                        android:id="@+id/text_magic_reveal_name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0"
                        android:gravity="center"
                        android:padding="16dp"
                        android:text="?"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:shadowColor="#000000"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="10"
                        android:textStyle="bold" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <!-- Predictions Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Sugestii bazate pe preferințele tale:"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.chip.Chip
                    android:id="@+id/prediction_1"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:text="🏛️ Muzee"
                    android:textSize="11sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/prediction_2"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:text="🌳 Parcuri"
                    android:textSize="11sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/prediction_3"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="🍽️ Mâncare"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_magic_go"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:text="VEZI REVELAȚIA"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            android:visibility="gone"
            app:cornerRadius="27dp"
            app:backgroundTint="@color/primary"
            app:elevation="4dp" />
            
        <!-- Close button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_magic_close"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="ÎNCHIDE"
            android:textColor="@color/app_text_hint"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
