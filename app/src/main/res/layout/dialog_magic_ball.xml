<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_magic_dialog_solid">

    <!-- Mystical Header -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="12dp"
        android:src="@drawable/ic_globe"
        app:tint="@color/primary" />

    <TextView
        android:id="@+id/text_magic_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GLOBUL DE CRISTAL"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.12" />

    <!-- PRE-SELECTION: What do you want to do? -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Ce cauți azi în destinul tău?"
        android:textColor="@color/primary_light"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:alpha="0.9" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_magic_cats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:chipSpacingHorizontal="8dp">
        
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_magic_food"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍕 Mâncare"
            app:chipBackgroundColor="@color/primary_faded"
            app:chipStrokeColor="@color/primary"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_magic_fun"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎮 Distracție"
            app:chipBackgroundColor="@color/primary_faded"
            app:chipStrokeColor="@color/primary"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_magic_relax"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🧘 Relaxare"
            app:chipBackgroundColor="@color/primary_faded"
            app:chipStrokeColor="@color/primary"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/white" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_magic_culture"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏛️ Cultural"
            app:chipBackgroundColor="@color/primary_faded"
            app:chipStrokeColor="@color/primary"
            app:chipStrokeWidth="1dp"
            android:textColor="@color/white" />
    </com.google.android.material.chip.ChipGroup>

    <!-- The Magical Sphere -->
    <RelativeLayout
        android:id="@+id/layout_magic_ball_container"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="24dp"
        android:gravity="center">

        <!-- Multiple Glow Layers for Depth -->
        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:background="@drawable/bg_magic_glow"
            android:alpha="0.4" />
        
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_magic_glow"
            android:alpha="0.2"
            app:tint="@color/accent_purple" />

        <androidx.cardview.widget.CardView
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_centerInParent="true"
            app:cardCornerRadius="120dp"
            app:cardBackgroundColor="#000000"
            app:cardElevation="40dp"
            android:outlineSpotShadowColor="@color/primary">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Crystal Ball Visual -->
                <ImageView
                    android:id="@+id/img_magic_reveal_ball"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_realistic_crystal_ball"
                    android:alpha="0.9" />

                <!-- Magic Mist for Transitions -->
                <ImageView
                    android:id="@+id/img_magic_reveal_mist"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0"
                    android:scaleType="centerCrop"
                    android:src="@drawable/img_magic_mist" />

                <!-- The Revealed Destination Name -->
                <TextView
                    android:id="@+id/text_magic_reveal_name"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0"
                    android:gravity="center"
                    android:padding="32dp"
                    android:text="?"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black"
                    android:shadowColor="@color/primary"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="25"
                    android:lineSpacingExtra="4dp" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <!-- Hidden Result Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_magic_go"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="32dp"
        android:text="URMEAZĂ-ȚI DESTINUL"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black"
        android:visibility="gone"
        app:cornerRadius="24dp"
        app:backgroundTint="@color/primary"
        app:elevation="12dp"
        app:rippleColor="#4DFFFFFF" />

</LinearLayout>
