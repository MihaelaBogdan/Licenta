<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/app_card"
    app:strokeColor="#1A10B981"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/text_magic_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_globul_de_cristal_b1f1f1"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:id="@+id/text_magic_instruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/auto_alege_o_categorie_si_apasa_pe_dcc4fe"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Category Selection Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_magic_cats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingHorizontal="8dp"
            android:gravity="center">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_magic_food"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_mancare_e962e3" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_magic_fun"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_distractie_b9a34a" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_magic_relax"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_relaxare_1404a7" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_magic_culture"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_cultural_fdafbe" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Crystal Ball Container with Green Glow -->
        <RelativeLayout
            android:id="@+id/layout_magic_ball_container"
            android:layout_width="260dp"
            android:layout_height="320dp"
            android:layout_marginVertical="4dp"
            android:clickable="true"
            android:focusable="true">

            <!-- Outer Glow Layer 1 - mare, dramatic -->
            <View
                android:id="@+id/view_glow_1"
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:layout_centerHorizontal="true"
                android:layout_alignParentTop="true"
                android:background="@drawable/bg_magic_glow"
                android:alpha="0.5" />

            <!-- Outer Glow Layer 2 - mai mic, intense -->
            <View
                android:id="@+id/view_glow_2"
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_magic_glow"
                android:alpha="0.35" />

            <!-- Suport ornamental (piedestal) sub sferă -->
            <ImageView
                android:id="@+id/img_crystal_stand"
                android:layout_width="210dp"
                android:layout_height="90dp"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/card_crystal_ball"
                android:layout_marginTop="-14dp"
                android:src="@drawable/ic_crystal_stand"
                android:scaleType="fitCenter" />

            <!-- Umbra care plutește sub piedestal (levitare) -->
            <View
                android:id="@+id/view_ball_shadow"
                android:layout_width="150dp"
                android:layout_height="18dp"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/img_crystal_stand"
                android:layout_marginTop="2dp"
                android:background="@drawable/bg_crystal_shadow"
                android:alpha="0.5" />

            <!-- Main Crystal Ball Sphere -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_crystal_ball"
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="15dp"
                app:cardCornerRadius="95dp"
                app:cardBackgroundColor="#000000"
                app:strokeColor="#1A10B981"
                app:strokeWidth="1dp"
                app:cardElevation="16dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Nebula animată 60fps: blob-uri care orbitează și se rotesc -->
                    <com.cityscape.app.ui.widget.CrystalBallView
                        android:id="@+id/view_crystal_ball"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Glint specultar animat - flash de lumină pe sticlă -->
                    <View
                        android:id="@+id/view_shimmer_glint"
                        android:layout_width="58dp"
                        android:layout_height="58dp"
                        android:layout_gravity="top|start"
                        android:layout_marginTop="10dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_specular_glint"
                        android:alpha="0" />

                    <!-- Textul predicției (ascuns până la reveal) -->
                    <TextView
                        android:id="@+id/text_magic_reveal_name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:alpha="0"
                        android:gravity="center"
                        android:padding="18dp"
                        android:text="?"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-black"
                        android:shadowColor="#00FF88"
                        android:shadowDx="0"
                        android:shadowDy="0"
                        android:shadowRadius="14"
                        android:textStyle="bold" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <!-- Predictions Display -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_sugestii_bazate_pe_preferintel_321433"
                android:textColor="@color/app_text_secondary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <com.google.android.material.chip.Chip
                    android:id="@+id/prediction_1"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:text="@string/auto_muzee_3157ba"
                    android:textSize="11sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/prediction_2"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:text="@string/auto_parcuri_a4caf2"
                    android:textSize="11sp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/prediction_3"
                    style="@style/Widget.MaterialComponents.Chip.Action"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/auto_mancare_aa795b"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_magic_go"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:text="@string/auto_vezi_revelatia_cd13ab"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:fontFamily="sans-serif-black"
            android:visibility="gone"
            app:cornerRadius="27dp"
            app:backgroundTint="@color/primary"
            app:elevation="4dp" />
            
        <!-- Close button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_magic_close"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="4dp"
            android:text="@string/auto_inchide_a74d7a"
            android:textColor="@color/app_text_hint"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
