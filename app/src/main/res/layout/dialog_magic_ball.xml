<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_glass_card_premium">

    <View
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:layout_marginBottom="20dp"
        android:background="#40FFFFFF"
        android:backgroundTint="@color/app_text_hint" />

    <TextView
        android:id="@+id/text_magic_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Consultăm Oracolul..."
        android:textColor="@color/primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Clarificăm viziunea pentru tine..."
        android:textColor="@color/app_text_secondary"
        android:textSize="14sp" />

    <androidx.cardview.widget.CardView
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="130dp"
        app:cardBackgroundColor="#000000"
        app:cardElevation="20dp"
        android:outlineSpotShadowColor="@color/accent_green"
        android:outlineAmbientShadowColor="@color/primary">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/img_magic_reveal_ball"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_realistic_crystal_ball" />

            <ImageView
                android:id="@+id/img_magic_reveal_mist"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:scaleType="centerCrop"
                android:src="@drawable/img_magic_mist" />

            <TextView
                android:id="@+id/text_magic_reveal_name"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:gravity="center"
                android:padding="32dp"
                android:text="?"
                android:textColor="@color/app_text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                android:shadowColor="#00FF88"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="25" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_magic_go"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Arată-mi Drumul"
        android:textAllCaps="false"
        android:visibility="gone"
        app:backgroundTint="@color/primary"
        app:cornerRadius="12dp" />

</LinearLayout>
