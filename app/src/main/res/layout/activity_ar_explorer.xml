<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <TextureView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- AR Overlay Layer -->
    <com.cityscape.app.ui.ar.AROverlayView
        android:id="@+id/ar_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- UI Layer -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:tint="@color/app_text_primary" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_login_gradient"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="12dp"
            android:alpha="0.8">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AR EXPLORER"
                android:textColor="@color/accent_green"
                android:textStyle="bold"
                android:letterSpacing="0.2"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_ar_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rotește telefonul pentru a descoperi"
                android:textColor="@color/app_text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_centerInParent="true"
            android:src="@drawable/ic_search"
            android:alpha="0.2"
            app:tint="@color/app_text_primary" />

    </RelativeLayout>

</FrameLayout>
