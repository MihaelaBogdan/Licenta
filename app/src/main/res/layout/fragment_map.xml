<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/app_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/app_text_hint" />

            <EditText
                android:id="@+id/map_search_input"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="12dp"
                android:background="@android:color/transparent"
                android:hint="@string/search_map_hint"
                android:textColor="@color/app_text_primary"
                android:textColorHint="@color/app_text_hint"
                android:textSize="14sp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    
    <HorizontalScrollView
        android:id="@+id/map_filter_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_nearby"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/auto_aproape_65f198"
                android:textColor="@color/app_text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/app_card"
                app:chipStrokeColor="@color/app_divider"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/primary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_favorites"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/auto_favorite_c339b4"
                android:textColor="@color/app_text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/app_card"
                app:chipStrokeColor="@color/app_divider"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/primary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_trending"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/auto_trend_6c5440"
                android:textColor="@color/app_text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/app_card"
                app:chipStrokeColor="@color/app_divider"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/primary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_restaurants"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/auto_restaurante_d6c466"
                android:textColor="@color/app_text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/app_card"
                app:chipStrokeColor="@color/app_divider"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/primary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_cafes"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/auto_cafenele_51dc24"
                android:textColor="@color/app_text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/app_card"
                app:chipStrokeColor="@color/app_divider"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/primary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_parks"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/auto_parcuri_a4caf2"
                android:textColor="@color/app_text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/app_card"
                app:chipStrokeColor="@color/app_divider"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/primary" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_filter_museums"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/auto_muzee_3157ba"
                android:textColor="@color/app_text_primary"
                android:checkable="true"
                app:chipBackgroundColor="@color/app_card"
                app:chipStrokeColor="@color/app_divider"
                app:chipStrokeWidth="1dp"
                app:checkedIconVisible="true"
                app:checkedIconTint="@color/primary" />

        </LinearLayout>
    </HorizontalScrollView>

    
    <androidx.cardview.widget.CardView
        android:id="@+id/card_selected_place"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/app_card"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <ImageView
                android:id="@+id/selected_place_image"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_corners_8" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/selected_place_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_origo_coffee_shop_10a76f"
                    android:textColor="@color/app_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/selected_place_address"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/auto_str_lipscani_9_c59cdc"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_star"
                            app:tint="@color/warning" />

                        <TextView
                            android:id="@+id/selected_place_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="@string/auto_48_4fb437"
                            android:textColor="@color/app_text_primary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btn_directions"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="16dp"
                        android:text="@string/directions"
                        android:textSize="12sp"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="8dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btn_my_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="120dp"
        android:text="@string/auto_locatia_mea_909438"
        android:textColor="@color/primary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        app:icon="@drawable/ic_location"
        app:iconTint="@color/primary"
        app:backgroundTint="@color/app_card"
        app:elevation="8dp"
        android:contentDescription="Revenire la locația curentă" />

</FrameLayout>
