<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@android:color/transparent">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <!-- Place Image -->
            <ImageView
                android:id="@+id/placeImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder_place"
                app:layout_collapseMode="parallax" />

            <!-- Gradient Overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_overlay" />

            <!-- Top Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp"
                app:layout_collapseMode="pin">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle"
                    android:src="@drawable/ic_back"
                    app:tint="@color/app_text_primary"
                    android:contentDescription="Back" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btnFavorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_icon_circle"
                    android:src="@drawable/ic_favorite_outline"
                    app:tint="@color/app_text_primary"
                    android:contentDescription="Favorite" />

                <ImageButton
                    android:id="@+id/btnShare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle"
                    android:src="@drawable/ic_share"
                    app:tint="@color/app_text_primary"
                    android:contentDescription="Share" />
            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Place Name & Rating -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/placeName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_place_name_ec8e16"
                        android:textColor="@color/app_text_primary"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-medium" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/placeCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_restaurant_e197a9"
                            android:textColor="@color/accent_green"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="8dp"
                            android:text="@string/auto_str_53fe08"
                            android:textColor="@color/app_text_secondary" />

                        <TextView
                            android:id="@+id/priceLevel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$$"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Rating Badge -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rating_badge"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/placeRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_45_c33ab4"
                        android:textColor="@color/app_text_primary"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/reviewCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_123_86418d"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Compatibility Score -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/your_compatibility"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/compatibilityLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/auto_great_match_633082"
                            android:textColor="@color/accent_green"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="60dp"
                        android:layout_height="60dp">

                        <ProgressBar
                            android:id="@+id/compatibilityProgress"
                            style="@android:style/Widget.Material.ProgressBar.Horizontal"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:max="100"
                            android:progress="85"
                            android:progressDrawable="@drawable/progress_circular"
                            android:rotation="-90" />

                        <TextView
                            android:id="@+id/compatibilityScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="@string/auto_85_42eed8"
                            android:textColor="@color/accent_green"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium" />
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Explainable Recommendation Analysis -->
            <androidx.cardview.widget.CardView
                android:id="@+id/aiAnalysisSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/auto_de_ce_tiam_recomandat_asta_1481e6"
                            android:textColor="@color/app_text_primary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/confidenceScoreBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_87_3fceea"
                            android:textColor="@color/gold_accent"
                            android:textSize="16sp"
                            android:fontFamily="sans-serif-medium"
                            android:background="@drawable/bg_glass_card"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>

                    <!-- Reasoning summary -->
                    <TextView
                        android:id="@+id/aiReasonText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/auto_corespunde_intereselor_tale_nu_224b8f"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.3" />

                    <!-- Factors Breakdown -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="14dp">

                        <!-- Factor 1: Interest Match -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/auto_potrivire_interese_5dd80d"
                                    android:textColor="@color/app_text_primary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/factor_interest"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_30_6d5608"
                                    android:textColor="@color/accent_green"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/factor_interest_progress"
                                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:max="100"
                                android:progress="30"
                                android:progressDrawable="@android:drawable/progress_horizontal"
                                android:indeterminate="false" />
                        </LinearLayout>

                        <!-- Factor 2: Freshness -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/auto_noutate_nu_ai_vizitat_40bb4a"
                                    android:textColor="@color/app_text_primary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/factor_freshness"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_25_ae0ce6"
                                    android:textColor="@color/accent_green"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/factor_freshness_progress"
                                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:max="100"
                                android:progress="25"
                                android:progressDrawable="@android:drawable/progress_horizontal"
                                android:indeterminate="false" />
                        </LinearLayout>

                        <!-- Factor 3: Popularity -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/auto_popularitate_e3fb40"
                                    android:textColor="@color/app_text_primary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/factor_popularity"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_20_a95b98"
                                    android:textColor="@color/accent_green"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/factor_popularity_progress"
                                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:max="100"
                                android:progress="20"
                                android:progressDrawable="@android:drawable/progress_horizontal"
                                android:indeterminate="false" />
                        </LinearLayout>

                        <!-- Factor 4: User Level -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="10dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/auto_nivel_potrivit_c9fb27"
                                    android:textColor="@color/app_text_primary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/factor_level"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_12_cdceec"
                                    android:textColor="@color/accent_green"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/factor_level_progress"
                                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:max="100"
                                android:progress="12"
                                android:progressDrawable="@android:drawable/progress_horizontal"
                                android:indeterminate="false" />
                        </LinearLayout>

                        <!-- Factor 5: Diversity -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/auto_diversitate_924bb5"
                                    android:textColor="@color/app_text_primary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/factor_diversity"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/auto_10_bb1a5a"
                                    android:textColor="@color/accent_green"
                                    android:textSize="11sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>

                            <ProgressBar
                                android:id="@+id/factor_diversity_progress"
                                style="@android:style/Widget.Material.ProgressBar.Horizontal"
                                android:layout_width="match_parent"
                                android:layout_height="4dp"
                                android:layout_marginTop="4dp"
                                android:max="100"
                                android:progress="10"
                                android:progressDrawable="@android:drawable/progress_horizontal"
                                android:indeterminate="false" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Total Confidence -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="0dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@android:color/darker_gray"
                        android:alpha="0.1">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/auto_total_incredere_1a28e1"
                            android:textColor="@color/app_text_primary"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/totalConfidence"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_97_878406"
                            android:textColor="@color/accent_green"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Address -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/placeAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/auto_123_street_name_city_9ca983"
                    android:textColor="@color/app_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Hours Section -->
            <LinearLayout
                android:id="@+id/hoursSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_clock"
                    app:tint="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/openingHours"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/auto_open_closes_10_pm_87b4b7"
                    android:textColor="@color/accent_green"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Description Section -->
            <LinearLayout
                android:id="@+id/descriptionSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about"
                    android:textColor="@color/app_text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/placeDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.3"
                    android:text="@string/auto_description_text_here_391a4b"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Atmosphere Section -->
            <LinearLayout
                android:id="@+id/atmosphereSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/atmosphere"
                    android:textColor="@color/app_text_primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/atmosphereTags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/auto_cozy_romantic_modern_fbca45"
                    android:textColor="@color/accent_green"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnCall"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_phone"
                            app:tint="@color/accent_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/call"
                            android:textColor="@color/app_text_primary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnWebsite"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="8dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_web"
                            app:tint="@color/accent_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/website"
                            android:textColor="@color/app_text_primary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnGetDirections"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/accent_green"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_directions"
                            app:tint="@color/primary_dark" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/directions"
                            android:textColor="@color/primary_dark"
                            android:textSize="12sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Write Review Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWriteReview"
                style="@style/Widget.CityScape.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="@string/write_review"
                android:textAllCaps="false"
                app:icon="@drawable/ic_review"
                app:iconGravity="textStart"
                app:strokeColor="@color/accent_green" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
