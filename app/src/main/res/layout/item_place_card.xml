<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="200dp"
    android:layout_height="280dp"
    android:layout_marginEnd="18dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="32dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@color/app_card">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Premium Base Image -->
            <ImageView
                android:id="@+id/place_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/primary" />

            <!-- Adaptive Scrim Overlay (Crucial for Light/Dark balance) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_overlay" />

            <!-- Sophisticated Rating Badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_star"
                    app:tint="@color/gold_accent" />

                <TextView
                    android:id="@+id/place_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="4.8"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Interaction Buttons Container (Horizontal Row at Top-Right) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btn_favorite"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="7dp"
                    android:src="@drawable/ic_favorite_border"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/btn_plan"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="7dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/white" />

                <ImageView
                    android:id="@+id/btn_visited"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="7dp"
                    android:src="@drawable/ic_check"
                    app:tint="@color/white" />
            </LinearLayout>

            <!-- Floating Content Capsule -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_margin="10dp"
                android:background="@drawable/bg_glass_card_premium"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/place_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="RESTAURANT"
                    android:textColor="@color/white"
                    android:textSize="8sp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/place_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="Place Name"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-condensed-medium"
                    android:textStyle="bold"
                    android:lineSpacingExtra="1dp" />

                <!-- Explainable Recommendation Info -->
                <LinearLayout
                    android:id="@+id/recommendation_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Overall Confidence Score & Inline Suggestion -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎯 Potrivire: "
                            android:textColor="#A7F3D0"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/confidence_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="87%"
                            android:textColor="@color/gold_accent"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="10dp"
                            android:layout_marginHorizontal="6dp"
                            android:background="#40FFFFFF" />

                        <TextView
                            android:id="@+id/ai_suggestion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Preferințe similare"
                            android:textColor="#A7F3D0"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-light" />
                    </LinearLayout>

                    <!-- Interest Match Score (if available) -->
                    <LinearLayout
                        android:id="@+id/interest_match_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💡 Interese: "
                            android:textColor="#A7F3D0"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/interest_match_score"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="30%"
                            android:textColor="@color/accent_green"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:src="@drawable/ic_location"
                        app:tint="#D1FAE5" />

                    <TextView
                        android:id="@+id/place_address"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Bucharest, RO"
                        android:textColor="#D1FAE5"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>
</androidx.cardview.widget.CardView>
