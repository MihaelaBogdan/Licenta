<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="80dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground">

    
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="6dp">

        
        <View
            android:id="@+id/story_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_story_ring_gradient" />

        
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_story_inner_circle">

            
            <TextView
                android:id="@+id/story_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="22sp"
                android:text="@string/auto_str_0a8b4b" />
        </FrameLayout>

        
        <FrameLayout
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/circle_red"
            android:backgroundTint="@color/error"
            android:elevation="4dp">

            <TextView
                android:id="@+id/story_hype_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/auto_str_cbe676"
                android:textSize="11sp" />
        </FrameLayout>

    </FrameLayout>

    
    <TextView
        android:id="@+id/story_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="@string/auto_locatie_6ea70b"
        android:textColor="@color/app_text_primary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    
    <TextView
        android:id="@+id/story_hype_score"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/auto_95_9b8185"
        android:textColor="@color/primary"
        android:textSize="9sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed" />

</LinearLayout>
