<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:layout_margin="20dp"
    android:background="@drawable/bg_magic_dialog_solid">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top Profile Row (Social Account style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <!-- Profile Avatar (Glass circular badge with emoji) -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_story_inner_circle">

                <TextView
                    android:id="@+id/dialog_story_emoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:textSize="22sp"
                    android:text="☕" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/dialog_story_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nume Locație"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />

                    <!-- Verified Badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" ✔️"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pulsul Social al Orașului"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <!-- LIVE Dot -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_badge"
                android:backgroundTint="#26EF4444"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_badge"
                    android:backgroundTint="#EF4444"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE"
                    android:textColor="#EF4444"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Social Media Post Card Style -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0DFFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <!-- Hype Score Bar/Display -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SCOR HYPE SOCIAL"
                    android:textColor="@color/gold_accent"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/dialog_story_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="95%"
                    android:textColor="@color/gold_accent"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true" />
            </RelativeLayout>

            <!-- Hype Progress Bar -->
            <ProgressBar
                android:id="@+id/dialog_story_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="100"
                android:progress="95"
                android:progressTint="@color/gold_accent"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DE CE ESTE ÎN TREND:"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/dialog_story_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Această locație a cunoscut o creștere masivă în popularitate datorită review-urilor pozitive din ultimele 24 de ore."
                android:textColor="#E2E8F0"
                android:textSize="13sp"
                android:lineSpacingExtra="4sp"
                android:fontFamily="sans-serif"
                android:textStyle="italic" />
        </LinearLayout>

        <!-- Dynamic Engagement Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp"
            android:paddingHorizontal="4dp">

            <TextView
                android:id="@+id/dialog_story_stat_checkins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📈 Activitate intensă detectată live"
                android:textColor="@color/secondary"
                android:textSize="12sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/dialog_story_stat_mentions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Foarte recomandat în rețelele sociale"
                android:textColor="@color/secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dialog_story_close"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="ÎNCHIDE"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_dialog_story_navigate"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="NAVIGHEAZĂ"
                android:textColor="@color/white"
                android:textSize="13sp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="8dp" />
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
