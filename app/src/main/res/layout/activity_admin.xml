<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="@color/app_card">

        <ImageButton
            android:id="@+id/btn_back_admin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:tint="@color/app_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Admin Panel"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐 ADMIN"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_dialog_rounded"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/admin_progress"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:indeterminate="true"
        android:progressTint="@color/primary"
        android:visibility="gone" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/admin_tabs"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/app_card"
        app:tabTextColor="@color/app_text_secondary"
        app:tabSelectedTextColor="@color/primary"
        app:tabIndicatorColor="@color/primary"
        app:tabMode="fixed">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 Statistici" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👥 Utilizatori" />
        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚨 Raportări" />
    </com.google.android.material.tabs.TabLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/panel_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Statistici generale"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_dialog_rounded"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="UTILIZATORI" android:textColor="#6B7280" android:textSize="10sp"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/stat_users" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="@color/primary" android:textSize="32sp"
                            android:fontFamily="sans-serif-black"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_dialog_rounded"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="POSTĂRI" android:textColor="#6B7280" android:textSize="10sp"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/stat_posts" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="#3B82F6" android:textSize="32sp"
                            android:fontFamily="sans-serif-black"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_dialog_rounded"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="BADGE-URI DATE" android:textColor="#6B7280" android:textSize="10sp"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/stat_badges" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="#F59E0B" android:textSize="32sp"
                            android:fontFamily="sans-serif-black"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:background="@drawable/bg_dialog_rounded"
                        android:padding="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="RAPORTĂRI" android:textColor="#6B7280" android:textSize="10sp"
                            android:fontFamily="sans-serif-medium" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/stat_likes" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="—"
                            android:textColor="#EF4444" android:textSize="32sp"
                            android:fontFamily="sans-serif-black"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_users"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toți utilizatorii"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#1A10B981"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Nume" android:textColor="@color/primary"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Email" android:textColor="@color/primary"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Lv." android:textColor="@color/primary"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="XP" android:textColor="@color/primary"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Creat" android:textColor="@color/primary"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_users"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panel_reports"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Raportări de conținut"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/reports_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✅ Nicio raportare activă"
                    android:textColor="#6B7280"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#1AEF4444"
                    android:paddingVertical="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Reporter" android:textColor="#EF4444"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Motiv" android:textColor="#EF4444"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Status" android:textColor="#EF4444"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Data" android:textColor="#EF4444"
                        android:textSize="11sp" android:paddingStart="16dp" android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_reports"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
