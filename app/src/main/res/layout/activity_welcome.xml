<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/image_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_welcome" />

    <!-- Gradient Overlay for better text readability and depth -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gradient_overlay" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@drawable/bg_glass_card"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CityScape"
            android:textColor="@color/app_text_primary"
            android:textSize="56sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed-medium"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Orașul tău, explorat."
            android:textColor="@color/accent_green"
            android:textSize="20sp"
            android:textStyle="normal"
            android:letterSpacing="0.05"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Descoperă locuri ascunse și experiențe unice."
            android:textColor="@color/app_text_secondary"
            android:textSize="18sp"
            android:lineSpacingMultiplier="1.2" />

        <!-- Main Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_get_started"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="40dp"
            android:text="@string/btn_get_started"
            android:textColor="@color/app_background"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="32dp"
            app:backgroundTint="@color/accent_green"
            app:elevation="8dp" />

        <!-- Social Login Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:text="@string/or_continue_with"
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_google"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:text="@string/google"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/app_text_hint"
            app:icon="@drawable/ic_google"
            app:iconGravity="textStart"
            app:iconTint="@null"
            app:cornerRadius="16dp" />

        <TextView
            android:id="@+id/text_already_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:text="@string/already_have_account_prompt"
            android:textColor="@color/app_text_primary"
            android:textSize="14sp"
            android:alpha="0.8" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
