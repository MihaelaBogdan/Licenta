<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="320dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="32dp"
    app:cardElevation="0dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/img_event"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_gradient_overlay" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_margin="12dp"
            android:background="@drawable/bg_glass_card_premium"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/text_event_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:text="@string/auto_12_mai_256c87"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:elevation="2dp"/>

            <TextView
                android:id="@+id/text_event_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="@string/auto_event_title_9502ef"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-condensed-medium"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_location"
                    app:tint="#D1FAE5" />

                <TextView
                    android:id="@+id/text_event_location"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/auto_location_details_ba250a"
                    android:textColor="#D1FAE5"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>

        
        <LinearLayout
            android:id="@+id/badge_ai_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:orientation="vertical"
            android:gravity="end"
            android:visibility="gone">

            <TextView
                android:id="@+id/badge_recommended"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_button_premium"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="@string/auto_92_a36111"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                app:backgroundTint="@null"/>

            <TextView
                android:id="@+id/text_ai_reason_card"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_glass_card"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:textColor="#EEFFFFFF"
                android:textSize="9sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone" />

        </LinearLayout>

        
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card_border_glow" />

    </FrameLayout>
</androidx.cardview.widget.CardView>
