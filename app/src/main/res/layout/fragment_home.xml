<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_main_gradient">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <!-- Elegant Profi Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingEnd="50dp">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/text_greeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_salut_01561d"
                            android:textColor="@color/app_text_primary"
                            android:textSize="20sp"
                            android:fontFamily="sans-serif-condensed-medium"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/text_weather"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_str_cfab1b"
                            android:textColor="@color/primary"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_filter_header"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_filter"
                        app:tint="@color/primary" />

                    <ImageButton
                        android:id="@+id/btn_reset_location"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_location"
                        android:visibility="gone"
                        app:tint="@color/primary" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_reveal_fate"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_glass_card"
                    android:padding="12dp"
                    android:src="@drawable/ic_crystal_ball"
                    app:tint="@color/primary" />
            </RelativeLayout>

            <!-- Offline Banner Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_offline_banner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/app_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_str_d1b276"
                        android:textSize="28sp"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_mod_offline_activ_1059d2"
                            android:textColor="@color/primary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/auto_chiar_daca_esti_in_avion_la_me_f41e5b"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NEXT LEVEL: Weather/Contextual Smart Recommendation Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_smart_recommendation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardMaxElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_smart_rec_card"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/txt_smart_emoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_str_7d39a1"
                            android:textSize="24sp"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_recomandare_inteligenta_89267e"
                                android:textColor="@color/smart_card_text_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_sugestia_personalizata_f8d6fd"
                                android:textColor="@color/app_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txt_smart_recommendation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_se_analizeaza_vremea_si_prefer_149121"
                        android:textColor="@color/smart_card_text_body"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.25" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NEXT LEVEL: Daily Quest Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_daily_quest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardMaxElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_daily_quest_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_badge"
                            android:layout_marginEnd="12dp"
                            app:tint="@color/quest_card_text_primary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_misiunea_zilei_3bb20c"
                                android:textColor="@color/quest_card_text_primary"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.08"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/text_quest_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_exploratorul_urban_386541"
                                android:textColor="@color/app_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/text_quest_reward"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_quest_reward_badge"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="@string/auto_500_xp_608dc0"
                            android:textColor="@color/quest_reward_text"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/text_quest_objective"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/auto_viziteaza_2_cafenele_si_postea_5356a8"
                        android:textColor="@color/quest_card_text_body"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.2" />

                    <TextView
                        android:id="@+id/text_quest_reason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/auto_pentru_ca_e_soare_e_timpul_per_d50641"
                        android:textColor="@color/quest_card_text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-italic" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <LinearLayout
                android:id="@+id/section_ai_picks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginHorizontal="6dp">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="@string/auto_recomandari_inteligente_d83c44"
                        android:textColor="@color/app_text_primary"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_ai_picks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:orientation="horizontal" />
            </LinearLayout>

            <!-- Content Tabs -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_plan_day"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:text="@string/auto_planificami_ziua_942235"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"
                android:background="@drawable/bg_button_premium"
                app:backgroundTint="@null"
                app:icon="@drawable/ic_calendar"
                app:iconSize="24dp"
                app:iconPadding="12dp"
                app:iconGravity="textStart" />

            <!-- Interactive Live Battle Home Screen Widget Card -->
            <!-- Interactive Live Battle Home Screen Widget Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_home_live_battle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardMaxElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardPreventCornerOverlap="false"
                app:cardUseCompatPadding="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_live_battle_card"
                    android:padding="16dp">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_confruntare_live_ce2092"
                            android:textColor="@color/app_text_primary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-black" />

                        <!-- Red LIVE Badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_live_ccbfd8"
                            android:textColor="#EF4444"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:background="#1AEF4444"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp" />
                    </LinearLayout>

                    <!-- Leader Indicator -->
                    <TextView
                        android:id="@+id/txt_home_battle_leader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:text="@string/auto_este_egalitate_acum_50_be3d83"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center" />

                    <!-- Clash Row (Horizontal) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Place A Column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/home_battle_name_a"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_ateneul_roman_57672c"
                                android:textColor="@color/app_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:maxLines="2"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/home_battle_pct_a"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_50_2496af"
                                android:textColor="@color/primary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <ProgressBar
                                android:id="@+id/home_battle_progress_a"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="10dp"
                                android:max="100"
                                android:progress="50"
                                android:progressTint="@color/primary" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_home_vote_a"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="@string/auto_voteaza_c58b2e"
                                android:textSize="11sp"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:backgroundTint="@color/primary"
                                app:cornerRadius="18dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingHorizontal="16dp" />
                        </LinearLayout>

                        <!-- VS Indicator in Middle -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auto_vs_2c54e2"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_quest_reward_badge"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:layout_marginHorizontal="10dp"
                            android:gravity="center" />

                        <!-- Place B Column -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/home_battle_name_b"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_teatrul_national_fbdd7c"
                                android:textColor="@color/app_text_primary"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:maxLines="2"
                                android:ellipsize="end" />

                            <TextView
                                android:id="@+id/home_battle_pct_b"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/auto_50_2496af"
                                android:textColor="#8B5CF6"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <ProgressBar
                                android:id="@+id/home_battle_progress_b"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="10dp"
                                android:max="100"
                                android:progress="50"
                                android:progressTint="#8B5CF6" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_home_vote_b"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="@string/auto_voteaza_c58b2e"
                                android:textSize="11sp"
                                android:textAllCaps="false"
                                android:textColor="@color/white"
                                android:backgroundTint="#8B5CF6"
                                app:cornerRadius="18dp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:paddingHorizontal="16dp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>



            <!-- Modern Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/primary" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/auto_cautare_destinatii_4cd742"
                    android:textColor="@color/app_text_primary"
                    android:textColorHint="@color/app_text_hint"
                    android:textSize="15sp"
                    android:imeOptions="actionSearch"
                    android:inputType="text" />

                <ImageButton
                    android:id="@+id/btn_mood_search"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_dice"
                    app:tint="@color/gold_accent" />

                <ImageButton
                    android:id="@+id/btn_filter"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/primary" />
            </LinearLayout>

            <!-- Active Filters List -->
            <HorizontalScrollView
                android:id="@+id/scroll_active_filters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                android:visibility="gone">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/active_filters_chip_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true" />
            </HorizontalScrollView>

            <!-- Categories -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/category_chip_group"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/category_all"
                        android:textColor="@color/app_background"
                        app:chipBackgroundColor="@color/primary"
                        app:chipCornerRadius="20dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_restaurants"
                        android:textColor="@color/app_text_primary"
                        app:chipBackgroundColor="@color/app_card"
                        app:chipCornerRadius="20dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_cafes"
                        android:textColor="@color/app_text_primary"
                        app:chipBackgroundColor="@color/app_card"
                        app:chipCornerRadius="20dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_parks"
                        android:textColor="@color/app_text_primary"
                        app:chipBackgroundColor="@color/app_card"
                        app:chipCornerRadius="20dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_museums"
                        android:textColor="@color/app_text_primary"
                        app:chipBackgroundColor="@color/app_card"
                        app:chipCornerRadius="20dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_culture"
                        android:textColor="@color/app_text_primary"
                        app:chipBackgroundColor="@color/app_card"
                        app:chipCornerRadius="20dp" />

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_commerce"
                        android:textColor="@color/app_text_primary"
                        app:chipBackgroundColor="@color/app_card"
                        app:chipCornerRadius="20dp" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Map Preview Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/explore_nearby"
                android:textColor="@color/app_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_map_preview"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/app_card"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <fragment
                        android:id="@+id/map_preview"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_gradient_overlay" />

                    <TextView
                        android:id="@+id/text_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="16dp"
                        android:text="@string/bucharest"
                        android:textColor="@color/app_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Near You Section -->
            <LinearLayout
                android:id="@+id/section_near_you"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/near_you_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/near_you"
                    android:textColor="@color/app_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_see_all_near_you"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_near_you"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal" />

            <!-- Visited Section -->
            <LinearLayout
                android:id="@+id/section_visited"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_locatii_vizitate_d9d5f1"
                    android:textColor="@color/app_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_see_all_visited"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/see_all"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_visited"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal"
                android:visibility="gone" />

            <!-- Events Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/events_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_evenimente_populare_d144db"
                    android:textColor="@color/app_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btn_filter_events"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="6dp"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/primary" />

                <TextView
                    android:id="@+id/btn_see_all_events"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/see_all"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_events"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <!-- Enhanced Trending Section Container -->
            <LinearLayout
                android:id="@+id/section_trending"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginHorizontal="16dp"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_explore"
                        app:tint="@color/gold_accent" />

                    <TextView
                        android:id="@+id/trending_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/auto_fii_la_curent_560546"
                        android:textColor="@color/app_text_primary"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/btn_see_all_trending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/see_all"
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/auto_descopera_locurile_emblematice_5c3eac"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="12sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_recommended"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />
                    
            </LinearLayout>

            <View 
                android:layout_width="match_parent"
                android:layout_height="100dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
