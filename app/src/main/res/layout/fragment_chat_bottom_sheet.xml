<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_chat_bottom_sheet"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp"
        android:background="@drawable/rounded_handle" />

    <!-- Premium Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <!-- Glowing AI Status Avatar -->
        <FrameLayout
            android:id="@+id/chat_avatar_container"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">
            
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circle_primary"
                android:alpha="0.15" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_smart_toy"
                app:tint="@color/primary"
                android:contentDescription="AI Icon" />

            <!-- Online Badge -->
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="1dp"
                android:background="@drawable/circle_online_badge" />
        </FrameLayout>

        <!-- Title / Subtitle -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/chat_avatar_container"
            android:layout_marginStart="12dp"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai_assistant"
                android:textColor="@color/app_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_online_raspunde_instant_eed65a"
                android:textColor="@color/primary"
                android:textSize="11sp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <!-- Close button -->
        <ImageButton
            android:id="@+id/btn_close_chat"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/app_text_secondary"
            android:contentDescription="Închide" />
    </RelativeLayout>

    <!-- Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/app_border"
        android:layout_marginBottom="8dp" />

    <!-- Chat Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chat_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:scrollbars="vertical" />

    <!-- Suggestions Container -->
    <HorizontalScrollView
        android:id="@+id/chat_suggestions_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:visibility="visible">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chat_suggestions_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true"
            app:chipSpacingHorizontal="8dp" />
    </HorizontalScrollView>

    <!-- Discussion Themes Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/auto_teme_de_discutie_e8c214"
        android:textColor="@color/app_text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <!-- Discussion Themes Group -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chat_themes_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleLine="true"
            app:chipSpacingHorizontal="8dp" />
    </HorizontalScrollView>

    <!-- Input Area Container (Card/Glass view) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_container"
        android:padding="4dp">

        <EditText
            android:id="@+id/chat_input"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="@string/type_message"
            android:paddingHorizontal="16dp"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_hint"
            android:textSize="14sp"
            android:inputType="textShortMessage|textAutoCorrect"
            android:maxLines="4" />

        <ImageButton
            android:id="@+id/chat_send_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="4dp"
            android:background="@drawable/bg_chat_send_btn"
            android:contentDescription="@string/ask_anything"
            android:padding="10dp"
            android:src="@drawable/ic_send"
            app:tint="@color/white" />
    </LinearLayout>

</LinearLayout>
