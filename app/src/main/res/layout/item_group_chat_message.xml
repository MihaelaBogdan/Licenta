<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingVertical="4dp"
    android:paddingHorizontal="12dp">

    <!-- Sender Name (only visible for others) -->
    <TextView
        android:id="@+id/txt_chat_sender_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_andrei_efc3f9"
        android:textColor="@color/primary"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="2dp"
        android:layout_marginStart="4dp" />

    <!-- Bubble Wrapper to align left/right -->
    <LinearLayout
        android:id="@+id/layout_bubble_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Message TextView -->
        <TextView
            android:id="@+id/txt_chat_message_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_sa_ne_vedem_la_intrare_f90c0b"
            android:textColor="@color/app_text_primary"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:maxWidth="270dp" />

    </LinearLayout>

</LinearLayout>
