<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tell_us"
            android:textColor="@color/app_text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setup_subtitle"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <!-- Categories Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/what_interests_you"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/categoryChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍽️ Restaurants"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ Cafes"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍸 Bars"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎭 Culture"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌳 Nature"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛍️ Shopping"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎉 Nightlife"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💼 Work-friendly"
                style="@style/Widget.CityScape.Chip.Choice" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Atmosphere Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/preferred_atmosphere"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/atmosphereChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cozy"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modern"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Romantic"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiet"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Family-friendly"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trendy"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Outdoor"
                style="@style/Widget.CityScape.Chip.Choice" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Budget Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/budget_preference"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <RadioGroup
            android:id="@+id/budgetRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/budgetLow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💰 Budget"
                android:textColor="@color/app_text_primary"
                android:buttonTint="@color/accent_green" />

            <RadioButton
                android:id="@+id/budgetMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:text="💰💰 Moderate"
                android:textColor="@color/app_text_primary"
                android:buttonTint="@color/accent_green" />

            <RadioButton
                android:id="@+id/budgetHigh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💰💰💰 Premium"
                android:textColor="@color/app_text_primary"
                android:buttonTint="@color/accent_green" />
        </RadioGroup>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Continue Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/get_started"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="28dp" />

        <!-- Skip Button -->
        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/skip_for_now"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
