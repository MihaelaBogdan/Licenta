<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tell_us"
            android:textColor="@color/app_text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setup_subtitle"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/what_interests_you"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/categoryChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_restaurants_7d5c2e"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_cafes_4328e7"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_bars_1815e5"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_culture_a4781e"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_nature_b30331"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_shopping_d4532a"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_nightlife_eb3522"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_workfriendly_32ae73"
                style="@style/Widget.CityScape.Chip.Choice" />
        </com.google.android.material.chip.ChipGroup>

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/preferred_atmosphere"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/atmosphereChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_cozy_97a03e"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_modern_ad1c9c"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_romantic_658410"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_quiet_098753"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_familyfriendly_6991a9"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_trendy_ed5d19"
                style="@style/Widget.CityScape.Chip.Choice" />

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_outdoor_8ef3d2"
                style="@style/Widget.CityScape.Chip.Choice" />
        </com.google.android.material.chip.ChipGroup>

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/budget_preference"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <RadioGroup
            android:id="@+id/budgetRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/budgetLow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_budget_7f8eed"
                android:textColor="@color/app_text_primary"
                android:buttonTint="@color/accent_green" />

            <RadioButton
                android:id="@+id/budgetMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:text="@string/auto_moderate_87f65e"
                android:textColor="@color/app_text_primary"
                android:buttonTint="@color/accent_green" />

            <RadioButton
                android:id="@+id/budgetHigh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_premium_e8ecb8"
                android:textColor="@color/app_text_primary"
                android:buttonTint="@color/accent_green" />
        </RadioGroup>

        
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/get_started"
            android:textAllCaps="false"
            android:textSize="16sp"
            app:backgroundTint="@color/accent_green"
            app:cornerRadius="28dp" />

        
        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:padding="16dp"
            android:text="@string/skip_for_now"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
