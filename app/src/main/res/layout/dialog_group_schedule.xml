<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/app_card"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Title with icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/circle_primary"
            android:padding="6dp"
            android:src="@drawable/ic_schedule"
            app:tint="@color/app_background" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Program disponibilitate"
            android:textColor="@color/app_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Setează când ești disponibil pentru această activitate"
        android:textColor="@color/app_text_secondary"
        android:textSize="13sp" />

    <!-- Date selector -->
    <TextView
        android:id="@+id/text_selected_schedule_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_rounded_surface"
        android:drawableStart="@drawable/ic_calendar"
        android:drawablePadding="8dp"
        android:drawableTint="@color/primary"
        android:padding="12dp"
        android:text="Selectează data"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp" />

    <!-- Time Range -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Start Time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="De la"
                android:textColor="@color/app_text_hint"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_start_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_rounded_surface"
                android:gravity="center"
                android:padding="14dp"
                android:text="09:00"
                android:textColor="@color/app_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="16dp"
            android:text="→"
            android:textColor="@color/primary"
            android:textSize="20sp" />

        <!-- End Time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Până la"
                android:textColor="@color/app_text_hint"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_end_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_rounded_surface"
                android:gravity="center"
                android:padding="14dp"
                android:text="18:00"
                android:textColor="@color/app_text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Status Toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sunt disponibil"
            android:textColor="@color/app_text_primary"
            android:textSize="15sp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_available"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:thumbTint="@color/primary"
            app:trackTint="@color/card_elevated" />
    </LinearLayout>

    <!-- Note -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.CityScape.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Notă (opțional)">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_schedule_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/card_elevated" />

    <!-- Members Schedule Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Disponibilitatea membrilor"
        android:textColor="@color/app_text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Members Schedule List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_member_schedules"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:nestedScrollingEnabled="false" />

    <!-- Empty state for schedules -->
    <TextView
        android:id="@+id/text_no_schedules"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:padding="20dp"
        android:text="Nimeni nu și-a setat programul încă"
        android:textColor="@color/app_text_hint"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
