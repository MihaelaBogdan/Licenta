<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_premium_dialog_light"
    android:padding="24dp">

    
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/app_divider" />

    
    <TextView
        android:id="@+id/txt_plan_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/auto_planifica_aventura_ad298d"
        android:textColor="@color/app_text_primary"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="18dp" />

    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_alege_data_2218ce"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_select_date"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="@string/auto_selecteaza_data_4017b1"
        android:textColor="@color/primary"
        app:strokeColor="@color/primary"
        app:cornerRadius="12dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:layout_marginBottom="16dp" />

    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_interval_orar_af78c2"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start_time"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/auto_de_la_1000_1030b9"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/app_divider"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_end_time"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/auto_pana_la_1200_252902"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/app_divider"
            app:cornerRadius="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_nivel_de_prioritate_cf4d7d"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cg_priority"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:checkedChip="@+id/chip_priority_high"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_priority_high"
            style="@style/Widget.CityScape.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_must_see_770d84" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_priority_med"
            style="@style/Widget.CityScape.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_flexible_b4dfb6" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_priority_low"
            style="@style/Widget.CityScape.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_optional_e0a738" />
    </com.google.android.material.chip.ChipGroup>

    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_buget_estimat_ron_62e7f6"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/input_budget"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_input_field"
        android:inputType="number"
        android:hint="@string/auto_ex_100_ron_775aaf"
        android:textColorHint="@color/app_text_hint"
        android:textColor="@color/app_text_primary"
        android:paddingHorizontal="16dp"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_mijloc_de_transport_preferat_a9df83"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cg_transit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:checkedChip="@+id/chip_transit_walk"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_transit_walk"
            style="@style/Widget.CityScape.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_pe_jos_66e99c" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_transit_bus"
            style="@style/Widget.CityScape.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_transport_in_comun_3ba03d" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_transit_car"
            style="@style/Widget.CityScape.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_autouber_30a060" />
    </com.google.android.material.chip.ChipGroup>

    
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_notite_amp_amintiri_ce9c93"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/input_notes"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_input_field"
        android:inputType="textMultiLine"
        android:hint="@string/auto_ex_cumpara_bilet_din_timp_fa_p_96bf42"
        android:textColorHint="@color/app_text_hint"
        android:textColor="@color/app_text_primary"
        android:padding="12dp"
        android:gravity="top|start"
        android:textSize="14sp"
        android:layout_marginBottom="24dp" />

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_plan"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="@string/auto_renunta_a6725a"
            android:textColor="@color/app_text_secondary"
            app:strokeColor="@color/app_divider"
            app:cornerRadius="14dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginEnd="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_plan"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1.5"
            android:text="@string/auto_salveaza_planul_d07522"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            android:fontFamily="sans-serif-medium"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_marginStart="6dp" />
    </LinearLayout>

</LinearLayout>
