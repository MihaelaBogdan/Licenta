<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Premium Background Image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/login_background" />

    <!-- Dark Overlay to make text pop -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_login_overlay" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back"
                    app:tint="@color/app_text_primary"
                    android:padding="12dp"
                    android:scaleType="centerInside" />
            </RelativeLayout>

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_location"
                app:tint="@color/primary"
                android:alpha="1.0" />

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="CityScape"
                android:textColor="@color/app_text_primary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed-medium"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/txtSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:text="Destinații fără limite"
                android:textColor="@color/app_text_secondary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light" />

            <!-- Glassmorphism Container with Animation Hook -->
            <LinearLayout
                android:id="@+id/loginCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_glass_card"
                android:orientation="vertical"
                android:padding="28dp"
                android:elevation="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="Bine ai revenit"
                    android:textColor="@color/app_text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:hintTextColor="@color/app_text_hint"
                    app:boxStrokeColor="@color/primary"
                    app:boxStrokeWidth="1.5dp"
                    android:hint="Email"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/primary"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
 
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/app_text_primary"
                        android:paddingStart="12dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:hintTextColor="@color/app_text_hint"
                    app:boxStrokeColor="@color/primary"
                    app:boxStrokeWidth="1.5dp"
                    android:hint="Parolă"
                    app:startIconDrawable="@drawable/ic_lock"
                    app:startIconTint="@color/primary"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="@color/app_text_hint"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
 
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/app_text_primary"
                        android:paddingStart="12dp"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Conectare"
                    android:textAllCaps="false"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    android:background="@drawable/bg_button_premium"
                    app:backgroundTint="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginVertical="16dp"
                    android:text="— SAU —"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="12sp"
                    android:letterSpacing="0.2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_google_sign_in"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Continuă cu Google"
                    android:textAllCaps="false"
                    android:textColor="@color/app_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="16dp"
                    app:backgroundTint="@color/app_background"
                    app:strokeColor="@color/app_text_hint"
                    app:strokeWidth="1dp"
                    app:icon="@drawable/ic_google"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconTint="@null"
                    app:elevation="4dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Nu ai cont? Înregistrează-te"
                android:textColor="@color/app_text_primary"
                android:textStyle="bold"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuest"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Intră ca vizitator"
                android:textAllCaps="false"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                app:rippleColor="@color/primary_faded" />

            <!-- Removed shortcut buttons -->

        </LinearLayout>
    </ScrollView>
</FrameLayout>
