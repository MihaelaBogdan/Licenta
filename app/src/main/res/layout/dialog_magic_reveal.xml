<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="@color/app_card"
    app:strokeColor="#1A10B981"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_recomandarea_ta_5874c8"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="16dp"/>

        
        <TextView
            android:id="@+id/reveal_place_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_locatie_secreta_596b28"
            android:textColor="@color/app_text_primary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-black"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#F0FDF4"
            app:strokeColor="#3310B981"
            app:strokeWidth="1dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/reveal_reason"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#065F46"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.2"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ce_poti_face_acolo_92732a"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp"
            android:layout_gravity="start"/>

        
        <TextView
            android:id="@+id/reveal_activities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp"
            android:lineSpacingExtra="6dp"
            android:layout_marginBottom="24dp"/>

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:spacing="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reveal_navigate"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/auto_aratami_traseul_8faa6a"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                app:cornerRadius="27dp"
                app:backgroundTint="@color/primary"
                app:icon="@drawable/ic_direction"
                app:iconGravity="textStart"
                app:iconTint="#FFFFFF"
                app:elevation="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reveal_share"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="@string/auto_invita_prietenii_89b9de"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:fontFamily="sans-serif-black"
                app:strokeColor="@color/primary"
                app:strokeWidth="1.5dp"
                app:cornerRadius="27dp"
                app:icon="@drawable/ic_share"
                app:iconGravity="textStart"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reveal_close"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/auto_inchide_a74d7a"
                android:textColor="@color/app_text_hint"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
