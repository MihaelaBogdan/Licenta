<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_premium_dialog_light"
    android:padding="24dp">

    <!-- Header bar (Handle) -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/app_divider" />

    <!-- Big post image with premium rounded corners -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        android:background="@android:color/transparent">

        <ImageView
            android:id="@+id/detail_post_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_place" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Place Type Chip -->
        <TextView
            android:id="@+id/detail_post_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="EXPLORARE"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Rating text and stars -->
        <TextView
            android:id="@+id/detail_post_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4.5"
            android:textColor="@color/gold_accent"
            android:textSize="14sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_star"
            android:drawablePadding="4dp"
            app:drawableTint="@color/gold_accent" />
    </LinearLayout>

    <!-- Place Name -->
    <TextView
        android:id="@+id/detail_post_place_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Numele Locației"
        android:textColor="@color/app_text_primary"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black" />

    <!-- Caption (Author review text) -->
    <TextView
        android:id="@+id/detail_post_caption"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Descrierea postării realizată de autor..."
        android:textColor="@color/app_text_secondary"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.2" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/app_divider" />

    <!-- Close button -->
    <Button
        android:id="@+id/btn_close_detail"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="16dp"
        android:text="Închide"
        android:textColor="@color/white"
        android:backgroundTint="@color/primary"
        app:cornerRadius="16dp" />

</LinearLayout>
