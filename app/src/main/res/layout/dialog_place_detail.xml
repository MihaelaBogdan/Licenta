<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_premium_dialog_light"
    android:padding="24dp">

    <!-- Header bar (Handle) -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/app_divider" />

    <!-- Place image with premium rounded corners -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        android:background="@android:color/transparent">

        <ImageView
            android:id="@+id/detail_place_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder_place" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Place Type Chip -->
        <TextView
            android:id="@+id/detail_place_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="@string/auto_atractie_b6351e"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Rating text and stars -->
        <TextView
            android:id="@+id/detail_place_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_45_c33ab4"
            android:textColor="@color/gold_accent"
            android:textSize="14sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_star"
            android:drawablePadding="4dp"
            app:drawableTint="@color/gold_accent" />

        <!-- Live Weather Badge -->
        <TextView
            android:id="@+id/detail_place_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/auto_22c_f418d7"
            android:textColor="@color/app_text_secondary"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Place Name -->
    <TextView
        android:id="@+id/detail_place_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/auto_numele_locatiei_31de30"
        android:textColor="@color/app_text_primary"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black" />

    <!-- Address -->
    <TextView
        android:id="@+id/detail_place_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/auto_adresa_9ba079"
        android:textColor="@color/app_text_secondary"
        android:textSize="13sp"
        android:drawableStart="@drawable/ic_location"
        android:drawablePadding="6dp"
        app:drawableTint="@color/app_text_secondary" />

    <!-- Vibeometer Premium Layout -->
    <LinearLayout
        android:id="@+id/layout_vibeometer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="12dp">

        <TextView
            android:id="@+id/vibe_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_str_e421f2"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/vibe_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_popular_amp_activ_energy_vibe_de2715"
                android:textColor="@color/app_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/vibe_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_multi_vizitatori_activi_in_ace_684ca3"
                android:textColor="@color/app_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- AI Summary / Gemini Reason Header with Speaker -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/lbl_ai_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/auto_sfatul_exploratorului_420905"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.03" />

        <ImageView
            android:id="@+id/btn_speak_ai"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ghid Audio AI"
            android:tint="@color/primary"
            android:padding="2dp" />
    </LinearLayout>

    <!-- AI Match Analysis Section (Advanced Breakdown) -->
    <LinearLayout
        android:id="@+id/aiAnalysisSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="16dp"
        android:visibility="gone">

        <!-- Title and Total Match Score -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_analiza_personalizare_ai_c30cdc"
                android:textColor="@color/app_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_total_confidence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_92_potrivire_62d9b2"
                android:textColor="@color/primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Factor 1: Interest Match -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_potrivire_interese_f38521"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txt_factor_interests"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_80_ab7ac8"
                    android:textColor="@color/primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <ProgressBar
                android:id="@+id/progress_factor_interests"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:max="100"
                android:progress="80"
                android:progressTint="@color/primary" />
        </LinearLayout>

        <!-- Factor 2: Freshness (Noutate) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_noutate_freshness_e77f24"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txt_factor_freshness"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_100_30bd7c"
                    android:textColor="@color/accent_purple"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <ProgressBar
                android:id="@+id/progress_factor_freshness"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:max="100"
                android:progress="100"
                android:progressTint="@color/accent_purple" />
        </LinearLayout>

        <!-- Factor 3: Popularity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_popularitate_amp_calitate_e6b5bf"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txt_factor_popularity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_90_f52f03"
                    android:textColor="@color/gold_accent"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <ProgressBar
                android:id="@+id/progress_factor_popularity"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:max="100"
                android:progress="90"
                android:progressTint="@color/gold_accent" />
        </LinearLayout>

        <!-- Factor 4: Explorer Level Match -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_potrivire_nivel_explorator_09ff20"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txt_factor_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_50_2496af"
                    android:textColor="#3B82F6"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <ProgressBar
                android:id="@+id/progress_factor_level"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:max="100"
                android:progress="50"
                android:progressTint="#3B82F6" />
        </LinearLayout>

        <!-- Factor 5: Category Diversity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_diversitate_categorii_4facff"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txt_factor_diversity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_80_ab7ac8"
                    android:textColor="#EC4899"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <ProgressBar
                android:id="@+id/progress_factor_diversity"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:max="100"
                android:progress="80"
                android:progressTint="#EC4899" />
        </LinearLayout>

        <!-- Factor 6: Weather & Time Match -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/auto_vreme_amp_moment_zi_9e8abf"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp" />
                <TextView
                    android:id="@+id/txt_factor_weather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/auto_80_ab7ac8"
                    android:textColor="#10B981"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
            <ProgressBar
                android:id="@+id/progress_factor_weather"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="2dp"
                android:max="100"
                android:progress="80"
                android:progressTint="#10B981" />
        </LinearLayout>

        <!-- Active Criteria (Interests & Filters) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"
            android:text="@string/auto_interese_amp_filtre_active_fb06b2"
            android:textColor="@color/app_text_primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/dialog_criteria_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="6dp"
            app:chipSpacingVertical="4dp"
            app:singleLine="false" />
    </LinearLayout>

    <!-- AI Summary Content -->
    <TextView
        android:id="@+id/detail_place_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/auto_aceasta_locatie_este_recomanda_bdfdf0"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.2" />

    <!-- Top Reviews Header -->
    <TextView
        android:id="@+id/lbl_reviews_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/auto_recenzii_de_top_google_reviews_97e765"
        android:textColor="@color/primary"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.03"
        android:visibility="gone" />

    <!-- Horizontal Scroll for Review Cards -->
    <HorizontalScrollView
        android:id="@+id/scroll_reviews"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/layout_reviews_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="4dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/app_divider" />

    <!-- Action buttons layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <!-- Plan button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_plan_place_detail"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/auto_planifica_3b64e0"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary"
            app:cornerRadius="16dp" />

        <!-- Close button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_place_detail"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/auto_inchide_9af4f3"
            android:textColor="@color/app_text_secondary"
            android:backgroundTint="@color/app_surface"
            app:strokeColor="@color/app_divider"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp" />
    </LinearLayout>

</LinearLayout>
