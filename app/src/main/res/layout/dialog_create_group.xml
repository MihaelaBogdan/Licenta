<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/app_card"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Creează un grup pentru această activitate și invită prietenii!"
        android:textColor="@color/app_text_secondary"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.3" />

    <!-- Group Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.CityScape.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:hint="Numele grupului">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_group_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Invite Following Section -->
    <TextView
        android:id="@+id/text_following_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Urmărești și poți invita:"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_following_to_invite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Invite by email Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="👥 Alte invitații (Email)"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="@color/card_elevated" />

    <!-- Share Link Option -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_whatsapp"
            app:tint="#25D366" />

        <TextView
            android:id="@+id/btn_share_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Creează și partajează pe WhatsApp"
            android:textColor="#25D366"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
