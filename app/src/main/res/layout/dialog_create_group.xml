<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Creează un grup"
        android:textColor="@color/app_text_primary"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Planifică această activitate împreună cu prietenii"
        android:textColor="@color/app_text_secondary"
        android:textSize="13sp" />

    <!-- Group Name Input -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.CityScape.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:hint="Numele grupului"
        app:startIconDrawable="@drawable/ic_group"
        app:startIconTint="@color/primary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_group_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/app_text_primary"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Recommended Friends Section -->
    <TextView
        android:id="@+id/text_recommended_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Prieteni recomandați:"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_recommended_friends"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:orientation="horizontal"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Invite Following Section -->
    <TextView
        android:id="@+id/text_following_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Urmărești și poți invita:"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_following_to_invite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- Invite by email Section -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.CityScape.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Caută după email"
        app:startIconDrawable="@drawable/ic_search"
        app:startIconTint="@color/app_text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_search_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textEmailAddress"
            android:textColor="@color/app_text_primary"
            android:textSize="14sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action Section -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_create_group_action"
        style="@style/Widget.Material3.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="Creează Grupul"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_glass_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_whatsapp"
            app:tint="#25D366" />

        <TextView
            android:id="@+id/btn_share_link"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Creează și partajează prin WhatsApp"
            android:textColor="#25D366"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

</LinearLayout>
