<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/app_card"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Place Name -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.CityScape.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Numele locului *"
        app:startIconDrawable="@drawable/ic_location"
        app:startIconTint="@color/primary">

        <AutoCompleteTextView
            android:id="@+id/input_place_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:completionThreshold="1"
            android:inputType="text"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Place Type -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.CityScape.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Tip (Restaurant, Café, etc.)"
        app:startIconDrawable="@drawable/ic_info"
        app:startIconTint="@color/app_text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_place_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Time Picker -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_clock"
            app:tint="@color/primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Ora:"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/input_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_rounded_surface"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:text="10:00"
            android:textColor="@color/primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Budget Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.CityScape.TextInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Buget"
            app:startIconDrawable="@drawable/ic_wallet"
            app:startIconTint="@color/primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/input_budget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="@color/app_text_primary"
                android:textColorHint="@color/app_text_hint" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_currency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            app:checkedButton="@+id/btn_ron"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_ron"
                style="@style/Widget.CityScape.Button.Toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RON" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_eur"
                style="@style/Widget.CityScape.Button.Toggle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EUR" />
        </com.google.android.material.button.MaterialButtonToggleGroup>
    </LinearLayout>

    <TextView
        android:id="@+id/text_conversion_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Conversie: 0.00 EUR"
        android:textColor="@color/accent_green"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- Notes -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.CityScape.TextInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Notițe (opțional)"
        app:startIconDrawable="@drawable/ic_review"
        app:startIconTint="@color/app_text_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/input_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:textColor="@color/app_text_primary"
            android:textColorHint="@color/app_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
