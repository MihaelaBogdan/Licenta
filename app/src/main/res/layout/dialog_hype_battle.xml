<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    android:background="@drawable/bg_live_battle_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:background="@color/app_divider" />

        <!-- Timer and XP Prize Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/hype_timer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏳ Se încheie în: --:--"
                android:textColor="@color/warning"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 Premiu: +300 XP"
                android:textColor="@color/gold_accent"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dialog Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/live_battle_title"
            android:textColor="@color/app_text_primary"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginBottom="6dp" />

        <!-- Suggestive Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/live_battle_desc"
            android:textColor="@color/app_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="20dp" />

        <!-- Place A Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardMaxElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card_premium"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/hype_img_a"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/placeholder_place" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/hype_name_a"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/app_text_primary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/hype_type_a"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="10sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <ProgressBar
                                android:id="@+id/hype_progress_a"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progressTint="@color/primary" />

                            <TextView
                                android:id="@+id/hype_pct_a"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textColor="@color/primary"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/hype_btn_vote_a"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:text="Votează"
                        android:textSize="10sp"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="8dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>

                <!-- Google Maps Review Bubble Place A -->
                <LinearLayout
                    android:id="@+id/hype_review_container_a"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_quest_reward_badge"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/hype_review_text_a"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:text="Căutăm recenzii de pe Google Maps..." />

                    <TextView
                        android:id="@+id/hype_review_author_a"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- VS Divider -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="⚡ VS ⚡"
            android:textColor="@color/warning"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:layout_marginVertical="2dp" />

        <!-- Place B Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardMaxElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_glass_card_premium"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.cardview.widget.CardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/hype_img_b"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/placeholder_place" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/hype_name_b"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/app_text_primary"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-black" />

                        <TextView
                            android:id="@+id/hype_type_b"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/app_text_secondary"
                            android:textSize="10sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">

                            <ProgressBar
                                android:id="@+id/hype_progress_b"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="0dp"
                                android:layout_height="6dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progressTint="#8B5CF6" />

                            <TextView
                                android:id="@+id/hype_pct_b"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:textColor="#8B5CF6"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/hype_btn_vote_b"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="8dp"
                        android:text="Votează"
                        android:textSize="10sp"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:backgroundTint="#8B5CF6"
                        app:cornerRadius="8dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>

                <!-- Google Maps Review Bubble Place B -->
                <LinearLayout
                    android:id="@+id/hype_review_container_b"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_battle_review_b"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/hype_review_text_b"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="italic"
                        android:text="Căutăm recenzii de pe Google Maps..." />

                    <TextView
                        android:id="@+id/hype_review_author_b"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#8B5CF6"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Dynamic Explorer Leaderboard Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/app_surface"
            app:strokeColor="@color/app_divider"
            app:strokeWidth="1dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏆 Top Exploratori (Leaderboard)"
                    android:textColor="@color/app_text_primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/battle_leaderboard_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <!-- Dynamic rows populated from Java code -->
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Current Most Voted Landmark Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/battle_results_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#0D10B981"
            app:strokeColor="#2610B981"
            app:strokeWidth="1.5dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👑"
                    android:textSize="28sp"
                    android:layout_marginEnd="12dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Locația Favorită în Timp Real"
                        android:textColor="@color/app_text_secondary"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txt_battle_winner_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Se încarcă liderul..."
                        android:textColor="@color/primary"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Close Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/hype_btn_close"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Închide"
            android:textColor="@color/app_text_primary"
            android:backgroundTint="@color/app_surface"
            app:strokeColor="@color/app_border"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
