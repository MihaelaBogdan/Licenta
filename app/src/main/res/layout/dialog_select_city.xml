<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_premium_dialog_light"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:id="@+id/dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Alege alt oraș"
        android:textColor="@color/app_text_primary"
        android:textSize="20sp"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="6dp" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/dialog_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Introdu destinația dorită sau selectează una populară:"
        android:textColor="@color/app_text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="16dp" />

    <!-- Search Input Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="4dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="@color/app_text_secondary" />

        <EditText
            android:id="@+id/input_city_name"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="Caută oraș..."
            android:textColorHint="@color/app_text_hint"
            android:textColor="@color/app_text_primary"
            android:background="@android:color/transparent"
            android:paddingHorizontal="12dp"
            android:textSize="15sp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:inputType="textPostalAddress|textCapWords" />
    </LinearLayout>

    <!-- Popular Cities Label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Destinații Populare"
        android:textColor="@color/app_text_primary"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp" />

    <!-- Popular Cities ChipGroup -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group_popular_cities"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="8dp"
        app:singleLine="false">

        <!-- Will be populated dynamically or statically -->
    </com.google.android.material.chip.ChipGroup>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <Button
            android:id="@+id/btn_cancel_city"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Anulează"
            android:textColor="@color/app_text_secondary" />

        <Button
            android:id="@+id/btn_explore_city"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:text="Explorează"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:backgroundTint="@color/primary"
            app:cornerRadius="10dp" />
    </LinearLayout>

</LinearLayout>
