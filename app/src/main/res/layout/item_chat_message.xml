<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="4dp">

    <!-- Bot Message (Left) -->
    <LinearLayout
        android:id="@+id/bot_message_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:maxWidth="300dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/circle_primary"
            android:padding="6dp"
            android:src="@drawable/ic_smart_toy" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/bot_message_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_message_bot"
                android:padding="12dp"
                android:textColor="@color/app_text_primary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/buttons_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />

            <!-- ITINERARY CARD ACTION inside Chat -->
            <androidx.cardview.widget.CardView
                android:id="@+id/chat_itinerary_card"
                android:layout_width="260dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_glass_card_premium"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/chat_itinerary_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗺️ Traseu AI Generat"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/chat_itinerary_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Planul este pregătit. Apasă mai jos pentru a-l deschide pe hartă!"
                        android:textColor="@color/app_text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/chat_itinerary_trail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Se încarcă opririle..."
                        android:textColor="@color/app_text_secondary"
                        android:textSize="11sp"
                        android:layout_marginBottom="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/chat_btn_view_itinerary"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="Deschide Traseul 🚀"
                        android:textSize="11sp"
                        android:textAllCaps="false"
                        android:textColor="@color/app_background"
                        android:backgroundTint="@color/primary"
                        app:cornerRadius="10dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>

    <!-- User Message (Right) -->
    <TextView
        android:id="@+id/user_message_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="@drawable/bg_message_user"
        android:maxWidth="280dp"
        android:padding="12dp"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:visibility="gone" />

</FrameLayout>
