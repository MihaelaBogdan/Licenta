<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_rounded_surface"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:background="@drawable/rounded_handle" />

    <TextView
        android:id="@+id/dialog_filter_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auto_filtre_avansate_e98135"
        android:textColor="@color/app_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Rating Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/auto_rating_minim_c4a5db"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filter_rating_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_rating_any"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_oricare_92c42d"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_rating_4"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_40_6a45d2" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_rating_45"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_45_348cc2" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Distance Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/auto_distanta_maxima_7e4168"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filter_distance_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_distance_any"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_oricare_92c42d"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_distance_2"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_2_km_589e3e" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_distance_5"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_5_km_8d7ba8" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_distance_10"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_10_km_269dd1" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_distance_20"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_20_km_1a07fb" />
    </com.google.android.material.chip.ChipGroup>

    <!-- Budget Selection -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/auto_nivel_pret_buget_8b2fb8"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filter_budget_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_budget_any"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_oricare_92c42d"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_budget_1"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_ieftin_55ffd1" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_budget_2"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_mediu_6d0ca1" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_budget_3"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_lux_560407" />
    </com.google.android.material.chip.ChipGroup>



    <!-- Music Type (for Events/Pubs) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/auto_gen_muzical_atmosfera_435158"
        android:textColor="@color/app_text_primary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/filter_music_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_music_all"
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_oricare_92c42d"
            android:checked="true" />

        <com.google.android.material.chip.Chip
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_electronic_techno_1d52e6" />

        <com.google.android.material.chip.Chip
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_pop_mainstream_3cee47" />

        <com.google.android.material.chip.Chip
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_rock_jazz_1abf70" />

        <com.google.android.material.chip.Chip
            style="@style/Widget.MaterialComponents.Chip.Choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_acustic_chill_d860ef" />
    </com.google.android.material.chip.ChipGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_apply_filters"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="@string/auto_aplica_filtre_c4fe53"
        android:textAllCaps="false"
        android:textStyle="bold"
        app:cornerRadius="16dp" />

</LinearLayout>
