<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/app_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Timeline/Time Indicator -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">
                
                <TextView
                    android:id="@+id/text_step_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="09:00"
                    android:textColor="@color/primary"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-black" />
                
                <TextView
                    android:id="@+id/text_slot_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MIC DEJUN"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="9sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Location Image with Shape -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_step"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/CityScapeCircle"
                android:background="@drawable/bg_glass_card"
                android:padding="2dp"
                android:src="@drawable/placeholder_place" />

            <!-- Details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_step_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nume Locație"
                    android:textColor="@color/app_text_primary"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/text_step_address"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Adresă locație"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/text_step_cost"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_glass_card"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="~50 RON"
                        android:textColor="@color/gold_accent"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/badge_closed_warning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_pill_primary_faded"
                        android:backgroundTint="@color/error"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:text="ÎNCHIS ACUM"
                        android:textColor="@color/white"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/text_distance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="1.2 km"
                        android:textColor="@color/primary"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Actions -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btn_step_swap"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@android:color/transparent"
                    android:padding="6dp"
                    android:src="@drawable/ic_refresh"
                    app:tint="@color/primary" />

                <ImageButton
                    android:id="@+id/btn_step_delete"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="4dp"
                    android:background="@android:color/transparent"
                    android:padding="6dp"
                    android:src="@drawable/ic_delete"
                    app:tint="@color/error" />
            </LinearLayout>
        </LinearLayout>


    </LinearLayout>
</androidx.cardview.widget.CardView>
