<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">
            
            <TextView
                android:id="@+id/text_slot_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mic Dejun"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:textStyle="bold" />
            
            <View
                android:layout_width="2dp"
                android:layout_height="30dp"
                android:background="@color/primary_faded"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_step"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedSquare"
            android:src="@drawable/placeholder_place" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_step_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nume Locație"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_step_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adresă locație"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
                
            <TextView
                android:id="@+id/text_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="1.2 km distanță"
                android:textColor="@color/primary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/text_step_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="~ 50 RON"
                android:textColor="@color/gold_accent"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/ic_back"
            android:rotation="180"
            app:tint="@color/text_secondary" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
