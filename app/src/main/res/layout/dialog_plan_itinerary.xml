<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/app_surface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Planifică aventura ta"
        android:textColor="@color/app_text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Unde vrei să explorăm astăzi?"
        android:textColor="@color/app_text_secondary"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/dialog_toggle_scope"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:checkedButton="@+id/btn_scope_nearby"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scope_nearby"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Aproape"
            android:textAllCaps="false"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scope_city"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tot orașul"
            android:textAllCaps="false"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/primary" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Ce stil preferi?"
        android:textColor="@color/app_text_secondary"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/dialog_toggle_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:checkedButton="@+id/btn_type_exploration"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_exploration"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Explorare"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_relaxation"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Relaxare"
            android:padding="0dp"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_cultural"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cultural"
            android:padding="0dp"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/primary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_type_gastronomic"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Foodie"
            android:padding="0dp"
            android:textSize="11sp"
            android:textAllCaps="false"
            android:textColor="@color/app_text_primary"
            app:strokeColor="@color/primary" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_generate_itinerary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="✨ Planifică"
        android:textAllCaps="false"
        android:textColor="@color/app_background"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:backgroundTint="@color/primary" />

</LinearLayout>
