<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_premium_dialog_light">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/auto_planifica_aventura_ta_decb83"
            android:textColor="@color/app_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/auto_unde_vrei_sa_exploram_astazi_816892"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/dialog_toggle_scope"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:checkedButton="@+id/btn_scope_nearby"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scope_nearby"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_aproape_bdbfcf"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                app:strokeColor="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scope_city"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_tot_orasul_8c20bb"
                android:textAllCaps="false"
                android:textColor="@color/app_text_primary"
                app:strokeColor="@color/primary" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Ce stil preferi?"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/dialog_style_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="false"
            app:selectionRequired="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_sport"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sport"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_relaxation"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Relaxare" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_cultural"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cultură" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_type_gastronomic"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gastronomic" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Transport"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/dialog_transport_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_transport_walking"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_pe_jos_66e99c"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_transport_transit"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_transport_public_73491f" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_transport_driving"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_masina_e82628" />
        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tip Grup"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/dialog_companion_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_companion_solo"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_singur_ebff74"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_companion_couple"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_cuplu_d9464e" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_companion_friends"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_prieteni_883a87" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_companion_family"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_familie_783013" />
        </com.google.android.material.chip.ChipGroup>

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_ora_de_start_342d65"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_start_hour_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_0800_5188aa"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/dialog_start_hour_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="8"
            android:valueFrom="6"
            android:valueTo="12"
            android:stepSize="1"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary"
            app:labelBehavior="gone" />

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_avoid_crowds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/auto_evita_locurile_aglomerate_1dd08c"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/auto_ce_vrei_sa_facem_neaparat_19ca6f"
            android:textColor="@color/app_text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/dialog_interest_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_include_cinema"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_cinema_1cf9d8" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_include_tennis"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_tenis_7f1a2c" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_include_museum"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_muzee_3157ba" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_include_park"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_parcuri_a4caf2" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_include_food"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_restaurante_85a859" />
        </com.google.android.material.chip.ChipGroup>

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_durata_ore_3a2cf7"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_duration_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_6h_41e8c1"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/dialog_duration_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="6"
            android:valueFrom="2"
            android:valueTo="24"
            android:stepSize="1"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary"
            app:labelBehavior="gone" />

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_numar_puncte_d57999"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_density_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_4_locatii_393b75"
                android:textColor="@color/primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/dialog_density_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:value="4"
            android:valueFrom="2"
            android:valueTo="10"
            android:stepSize="1"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary"
            app:labelBehavior="gone" />

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/auto_buget_maxim_befed1"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_budget_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/auto_250_ron_0e264b"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/dialog_budget_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:value="250"
            android:valueFrom="50"
            android:valueTo="1000"
            android:stepSize="50"
            app:thumbColor="@color/primary"
            app:trackColorActive="@color/primary"
            app:labelBehavior="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_generate_itinerary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="@string/auto_planifica_28bec3"
            android:textAllCaps="false"
            android:textColor="@color/app_background"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/primary" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
