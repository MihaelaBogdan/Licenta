<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Main DayNight Application Theme -->
    <style name="Base.Theme.CityScape" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        
        <!-- Use semantic colors that switch in values and values-night -->
        <item name="android:colorBackground">@color/app_background</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:statusBarColor">@color/app_background</item>
        <item name="android:navigationBarColor">@color/app_surface</item>
        
        <item name="colorSurface">@color/app_surface</item>
        <item name="android:textColorPrimary">@color/app_text_primary</item>
        <item name="android:textColorSecondary">@color/app_text_secondary</item>
        <item name="android:textColorHint">@color/app_text_hint</item>
    </style>

    <!-- App Theme Wrapper -->
    <style name="Theme.CityScape" parent="Base.Theme.CityScape" />

    <!-- Adaptive Dialog Theme (Switches between light/dark automatically) -->
    <style name="CityScapeDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/app_card</item>
        <item name="android:textColorPrimary">@color/app_text_primary</item>
        <item name="android:textColorSecondary">@color/app_text_secondary</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/accent_green</item>
    </style>
    
    <!-- Legacy support to avoid immediate compilation errors -->
    <style name="DarkDialogTheme" parent="CityScapeDialogTheme" />

    <!-- Style definitions for components -->
    <style name="Widget.CityScape.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent_green</item>
        <item name="hintTextColor">@color/accent_green</item>
        <item name="android:textColorHint">@color/app_text_hint</item>
        <item name="boxBackgroundColor">@color/app_surface</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="Widget.CityScape.Chip.Choice" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/app_surface</item>
        <item name="chipStrokeColor">@color/app_text_hint</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="checkedIconVisible">true</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="checkedIconTint">@color/accent_green</item>
    </style>

    <style name="Widget.CityScape.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/app_text_hint</item>
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="TextAppearance.CityScape.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/app_text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.CityScape.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/app_text_hint</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="CalendarDateStyle" parent="android:TextAppearance.DeviceDefault.Small">
        <item name="android:textColor">@color/app_text_primary</item>
    </style>

    <style name="CalendarWeekDayStyle" parent="android:TextAppearance.DeviceDefault.Small">
        <item name="android:textColor">@color/app_text_secondary</item>
    </style>

    <style name="Widget.CityScape.Button.Toggle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/app_text_primary</item>
        <item name="strokeColor">@color/accent_green</item>
        <item name="rippleColor">@color/primary_faded</item>
    </style>

    <style name="RoundedSquare">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="TransparentBottomSheetDialogTheme" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:windowIsFloating">false</item>
    </style>
</resources>