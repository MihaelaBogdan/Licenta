<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Licenta" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
    </style>

    <style name="Theme.Licenta" parent="Base.Theme.Licenta" />
    
    <!-- Dark Dialog Theme -->
    <style name="DarkDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">@color/card_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    
    <!-- Calendar Styles -->
    <style name="CalendarDateStyle" parent="android:TextAppearance.DeviceDefault.Small">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="CalendarWeekDayStyle" parent="android:TextAppearance.DeviceDefault.Small">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- CityScape Widget Styles -->
    <style name="Widget.CityScape.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent_green</item>
        <item name="hintTextColor">@color/accent_green</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxBackgroundColor">@color/surface_dark</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="Widget.CityScape.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/text_hint</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="TextAppearance.CityScape.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.CityScape.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Theme.CityScape" parent="Theme.Licenta">
        <item name="colorAccent">@color/accent_green</item>
    </style>

    <style name="Widget.CityScape.Chip.Choice" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_dark</item>
        <item name="chipStrokeColor">@color/text_hint</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="checkedIconVisible">true</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="checkedIconTint">@color/accent_green</item>
        <item name="chipSurfaceColor">@color/accent_green</item>
    </style>
</resources>