<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" 
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"
        tools:ignore="ScopedStorage" />

    <application
        android:name=".CityScapeApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CityScape"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- Google Places API -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <!-- Splash/Welcome Activity -->
        <activity
            android:name=".activities.WelcomeActivity"
            android:exported="true"
            android:theme="@style/Theme.CityScape.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Authentication Activity -->
        <activity
            android:name=".activities.AuthActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Profile Setup Activity -->
        <activity
            android:name=".activities.ProfileSetupActivity"
            android:exported="false" />

        <!-- Main Activity (Navigation Host) -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <!-- Place Details Activity -->
        <activity
            android:name=".activities.PlaceDetailActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Itinerary Activity -->
        <activity
            android:name=".activities.ItineraryActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Chatbot Activity -->
        <activity
            android:name=".activities.ChatbotActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- City Selection Activity -->
        <activity
            android:name=".activities.CitySelectActivity"
            android:exported="false" />

        <!-- Settings Activity -->
        <activity
            android:name=".activities.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Propose Place Activity -->
        <activity
            android:name=".activities.ProposePlaceActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

        <!-- Calendar Activity -->
        <activity
            android:name=".activities.CalendarActivity"
            android:exported="false"
            android:parentActivityName=".activities.MainActivity" />

    </application>

</manifest>
